# Required
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_GENAI_USE_VERTEXAI=True

# Optional
DATAPLEX_GLOSSARY_LOCATION=global
DATAPLEX_API_ENDPOINT=dataplex.googleapis.com
GLOSSARY_AGENT_MODEL=gemini-3-flash-preview
GLOSSARY_AGENT_MAX_GCS_DOCS=50
GLOSSARY_AGENT_MAX_DOC_BYTES=524288

# Document AI (enables PDF / image / DOCX ingestion).
# Leave DOCUMENT_AI_PROCESSOR_ID empty to disable; binary docs will be skipped.
# Recommended processor type: Layout Parser (handles PDF, DOCX, PPTX, XLSX, HTML, TXT)
# or general OCR for PDFs + scanned images only.
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_PROCESSOR_VERSION=
